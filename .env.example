# Copy to .env only on your own computer. Never commit or send the filled file.
# The application must remain disabled until programmatic-trading registration,
# simulation permission, and the broker-provided CTP SDK are ready.
CJFCO_USER_ID=
CJFCO_PASSWORD=
CJFCO_APP_ID=
CJFCO_AUTH_CODE=
FUTURES_QUANT_LIVE_ENABLED=false
FUTURES_QUANT_LIVE_ARM_TOKEN=

# OKX subaccount API. Keep values only in your local .env or process environment.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_EXPECTED_UID=
OKX_EXPECTED_MAIN_UID=
