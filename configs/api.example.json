{
  "gateway": "ctp",
  "broker_name": "期货公司仿真环境",
  "broker_id": "your_broker_id",
  "trade_front": "tcp://your-trade-front:port",
  "market_front": "tcp://your-md-front:port",
  "api_version": "broker-supported-version",
  "adapter": "your_ctp_adapter.module:create_adapter",
  "mode": "paper",
  "enabled": false,
  "live_trading_enabled": false,
  "programmatic_trading_report_confirmed": false,
  "user_id_env": "CTP_USER_ID",
  "password_env": "CTP_PASSWORD",
  "app_id_env": "CTP_APP_ID",
  "auth_code_env": "CTP_AUTH_CODE",
  "settlement_confirmation_required": true,
  "heartbeat_timeout_seconds": 45,
  "reconnect_initial_delay_seconds": 2,
  "reconnect_max_delay_seconds": 60,
  "reconnect_max_attempts": 8,
  "live_arm_timeout_seconds": 300,
  "risk_limits": {
    "max_order_volume": 5,
    "max_abs_position_per_symbol": 50,
    "max_open_symbols": 5,
    "max_pending_orders": 20,
    "max_daily_order_requests": 100,
    "max_symbol_margin_fraction": 0.2,
    "max_total_margin_fraction": 0.6
  },
  "instruments": {}
}
